# Where the FastAPI backend lives. The Vite dev server proxies
# /api/* and /ws/* to this target so the PWA can use relative URLs.
VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# Optional: in production set this to your deployed API origin
# (used at runtime when /api isn't same-origin)
# VITE_API_BASE_URL=https://api.petpooja.example.com
